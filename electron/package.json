{
  "name": "reunioes",
  "version": "1.0.0",
  "description": "Gravação e transcrição de reuniões",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "build": "electron-builder --linux"
  },
  "build": {
    "appId": "com.reunioes.app",
    "productName": "Reuniões",
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility",
      "maintainer": "tereza@anne.today",
      "icon": "assets/icon.png",
      "desktop": {
        "Name": "Reuniões",
        "StartupWMClass": "reunioes"
      }
    },
    "extraResources": [
      {
        "from": "../dist/server",
        "to": "server",
        "filter": ["**/*"]
      }
    ],
    "files": ["main.js", "assets/**"]
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0"
  }
}
