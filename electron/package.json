{
  "name": "Sekra",
  "version": "1.0.0",
  "description": "Gravação e transcrição de reuniões",
  "author": "Patrick Cremonese <desvprog@gmail.com>",
  "homepage": "https://github.com/Desvprog/Sekra",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "build": "electron-builder --linux"
  },
  "build": {
    "appId": "com.sekra.app",
    "productName": "Sekra",
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "maintainer": "Patrick Cremonese <desvprog@gmail.com>",
      "icon": "assets/icon.png",
      "desktop": {
        "Name": "Sekra",
        "StartupWMClass": "sekra"
      }
    },
    "extraResources": [
      {
        "from": "../dist/server",
        "to": "server",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "main.js",
      "assets/**"
    ]
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-builder"
    ]
  }
}
